pipeline {
    agent any

    tools {
        // Use the NodeJS installation defined in Jenkins Global Tool Configuration
        nodejs 'node_12.0.0'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build') {
            steps {
                sh 'npm install'
                sh 'npm run build'
                echo 'Building..right now'
            }
        }
        stage('Test') {
            steps {
                echo 'Testing..now'
            }
        }
        stage('Deploy') {
            steps {
                echo 'Deploying....now'
            }
        }
    }
}