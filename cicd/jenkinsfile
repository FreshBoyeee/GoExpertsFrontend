pipeline {
    agent any

    // tools {
    //     // Use the NodeJS installation defined in Jenkins Global Tool Configuration
    //     nodejs 'node_12.0.0'
    // }

    environment {
        // Replace 'your-aws-credentials-id' with the ID you've assigned to the AWS credentials in Jenkins
        AWS_CREDENTIALS = credentials('goExpertUser')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build') {
            steps {
                // sh 'npm install'
                // sh 'npm run build'
                echo 'Building..right now'
            }
        }
        stage('Test') {
            steps {
                echo 'Testing..now'
            }
        }
        stage('Deploy') {
            steps {
                sh 'aws s3 sync ../build s3://angfubucket'
                echo 'Deploying....now'
            }
        }
    }
}