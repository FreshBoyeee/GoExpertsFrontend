pipeline {
    agent any
    stages {
        stage('Build') { 
            steps {
                sh 'curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh | bash'
                sh 'export NVM_DIR="$HOME/.nvm"'
                sh '[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"'  
                sh '[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion" ' 
                sh 'nvm install v12'
                sh 'nvm use v12'
                sh 'npm -v'
                sh 'node -v'
                sh 'npm install'
                sh 'npm run build'
                echo "building..."
            }
        }
    }
}