pipeline {
    agent any
    stages {
        stage('Build') { 
            steps {
                // sh 'npm install'
                // sh 'npm run build'
                sh 'sudo yum remove awscli'
                sh 'curl "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o "awscliv2.zip"
unzip awscliv2.zip
sudo ./aws/install'
                sh 'aws --version'
            }
        }
    }
}