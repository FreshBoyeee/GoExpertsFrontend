pipeline {
    agent any
    stages {
        stage('Build') { 
            steps {
                sh 'npm install'
                sh 'npm run build'
                sh 'aws s3 mb s3://goexpertangfutestbucket'
                sh 'aws s3 cp build s3://goexpertangfutestbucket/ --recursive'
                sh 'aws s3 ls'
                sh 'aws s3 ls s3://goexpertangfutestbucket --recursive --human-readable --summarize'

            }
        }
    }
}