pipeline {
    agent any
    stages {
        stage('Build') { 
            steps {
                sh 'source ~/.nvm/nvm.sh'
                sh 'nvm install v12'
                sh 'nvm use v12'
                sh 'npm -v'
                sh 'node -v'
                sh 'npm install'
                sh 'npm run build'
                echo "building..."
            }
        }
    }
}